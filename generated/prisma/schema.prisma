generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Users ────────────────────────────────────────────────────────────────────
// Mirrors auth.users from Supabase. Created automatically by a DB trigger
// (see supabase/migrations/001_handle_new_user.sql) — do not insert manually.

model User {
  id        String   @id // UUID from auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos     Photo[]
  portfolios Portfolio[]
  linksPages LinksPage[]
  deliveries Delivery[]
}

// ── Photo library ─────────────────────────────────────────────────────────────
// Master library for all uploaded photos (used by both delivery and portfolio).
// Files live in Supabase Storage bucket "photos" at storagePath.

model Photo {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url         String // public URL (Supabase Storage)
  storagePath String // path within the bucket e.g. "userId/timestamp-filename.jpg"
  filename    String
  size        Int // bytes
  width       Int?
  height      Int?
  mimeType    String   @default("image/jpeg")
  createdAt   DateTime @default(now())

  deliveryPhotos DeliveryPhoto[]

  @@index([userId])
}

// ── Portfolio sites ───────────────────────────────────────────────────────────
// Each user can have multiple portfolio sites. The full content tree
// (categories → folders → photos) is stored as JSON to avoid complex
// normalisation in v1 — matches the PortfolioContent type in lib/portfolio/data.ts.

model Portfolio {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  slug         String  @unique
  status       String  @default("draft") // draft | published
  template     String  @default("minimal")
  customDomain String? @unique

  // Shape: { categoryIds, categories, folders, photos } — see lib/portfolio/data.ts
  content Json @default("{}")

  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── Links pages ───────────────────────────────────────────────────────────────
// Linktree-style pages. Fields mirror the LinksPage type in lib/links/data.ts.
// One per user for v1 (getMine returns the first match).

model LinksPage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  template String @default("brooklyn")

  // Profile
  displayName   String @default("")
  bio           String @default("")
  avatarUrl     String @default("")
  avatarBg      String @default("")
  avatarInitial String @default("")

  // Background
  bgType           String @default("solid")
  bgColor          String @default("#111111")
  bgGradFrom       String @default("#111111")
  bgGradTo         String @default("#333333")
  bgGradAngle      Int    @default(135)
  bgImageUrl       String @default("")
  bgOverlayColor   String @default("#000000")
  bgOverlayOpacity Float  @default(0.4)

  // Buttons
  btnShape   String @default("square")
  btnVariant String @default("filled")
  btnBg      String @default("#fad502")
  btnText    String @default("#111111")
  btnBorder  String @default("#fad502")

  // Typography
  fontFamily String @default("")
  fontWeight String @default("400")
  textColor  String @default("#F0EFE9")
  subColor   String @default("#7A7A7A")

  // Per-template label overrides (marquee text, stats, eyebrow, etc.)
  labels Json @default("{}")

  // Publishing
  slug      String? @unique
  published Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links LinkItem[]

  @@index([userId])
}

// ── Link items ────────────────────────────────────────────────────────────────
// Individual rows in a links page. Fields mirror the LinkItem type.

model LinkItem {
  id          String    @id @default(cuid())
  linksPageId String
  linksPage   LinksPage @relation(fields: [linksPageId], references: [id], onDelete: Cascade)

  type    String  @default("link") // link | divider | whatsapp | instagram | email | delivery
  title   String  @default("")
  url     String  @default("")
  enabled Boolean @default(true)
  order   Int     @default(0)
  icon    String  @default("")

  // WhatsApp
  waCountry String?
  waPhone   String?
  waMessage String?

  // Instagram
  igUsername String?

  // Email
  emailAddress String?
  emailSubject String?

  createdAt DateTime @default(now())

  @@index([linksPageId])
}

// ── Client delivery galleries ─────────────────────────────────────────────────
// Fields mirror the DeliveryPage type in lib/delivery/data.ts.
// Photos are linked via the DeliveryPhoto join table.

model Delivery {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core
  title    String @default("")
  client   String @default("")
  status   String @default("draft") // draft | active | expired
  template String @default("halcyon") // halcyon | brooklyn | minimal | vogue
  layout   String @default("masonry") // grid | masonry

  // Cover
  coverUrl       String @default("")
  coverFit       String @default("cover")
  coverPositionX Float  @default(50)
  coverPositionY Float  @default(50)

  // Security
  passwordEnabled  Boolean  @default(false)
  password         String   @default("")
  whitelistEnabled Boolean  @default(false)
  whitelist        String[] @default([])

  // Password page copy
  passwordTitle       String @default("Private gallery")
  passwordSubtitle    String @default("Enter the access code to view.")
  passwordHint        String @default("")
  passwordButtonLabel String @default("Unlock gallery")

  // Monetization
  mode             String @default("gift") // gift | direct
  pricePerPhoto    Float  @default(0)
  priceFullGallery Float  @default(0)
  downloadRes      String @default("choice") // full | web | choice

  // Branding
  logoMode  String @default("text") // none | text | image | image+text
  logoText  String @default("STUDIO")
  logoUrl   String @default("")
  logoWidth Int    @default(0)

  // Custom colors
  customColors Boolean @default(false)
  colorBg      String  @default("#ffffff")
  colorFg      String  @default("#111111")
  colorAccent  String  @default("#f5f5f5")
  colorBtnBg   String  @default("#111111")
  colorBtnFg   String  @default("#ffffff")

  // Typography slots
  fontFamily  String @default("")
  fontFamily1 String @default("")
  fontFamily2 String @default("")
  fontFamily3 String @default("")

  // Misc
  welcomeMessage   String  @default("")
  showUpsellBanner Boolean @default(false)

  // Per-template label overrides
  labels Json @default("{}")

  // Publishing
  slug      String?   @unique
  views     Int       @default(0)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos DeliveryPhoto[]

  @@index([userId])
}

// ── Delivery ↔ Photo join ─────────────────────────────────────────────────────

model DeliveryPhoto {
  id         String   @id @default(cuid())
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  photoId    String
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  order      Int      @default(0)

  @@unique([deliveryId, photoId])
  @@index([deliveryId])
}
